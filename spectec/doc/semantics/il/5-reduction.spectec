rule Step_exp/INJ-ctx2:
  S |- INJ t mixop e `- qpr? ~> INJ t mixop e' `- qpr?
  -- Step_exp: S |- e ~> e'

rule Step_exp/INJ-ctx-fail2:
  S |- INJ t mixop e `- qpr? ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/INJ-ctx3:
  S |- INJ t mixop e `- qpr ~> INJ t mixop e `- qpr'
  -- Step_quantprems: S |- qpr ~> qpr'

rule Step_exp/INJ-ctx-fail3:
  S |- INJ t mixop e `- qpr ~> eps
  -- Step_quantprems: S |- qpr ~> eps


rule Step_exp/LIFT-ctx:
  S |- LIFT e ~> LIFT e'
  -- Step_exp: S |- e ~> e'

rule Step_exp/LIFT-ctx-fail:
  S |- LIFT e ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/LEN-ctx:
  S |- LEN e ~> LEN e'
  -- Step_exp: S |- e ~> e'

rule Step_exp/LEN-ctx-fail:
