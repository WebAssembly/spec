;; rule Step_prems/fail-prem:
;;   S |- Prem(pr) ~>_{} eps
;;   -- Step_prems: S |- pr ~>_s eps
;;
;; rule Step_prems/ctx-typ:
;;   S |- PremTyp(t) ~>_{} PremTyp(t')
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_prems/fail-typ:
;;   S |- PremTyp(t) ~>_{} eps
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_prems/ctx-exp:
;;   S |- PremExp(e) ~>_{} PremExp(e')
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_prems/fail-exp:
;;   S |- PremExp(e) ~>_{} eps
;;   -- Step_exp: S |- e ~> eps
;;
;; rule Step_prems/ctx-param:
;;   S |- PremParam(q) ~>_{} PremParam(q')
;;   -- Step_param: S |- q ~> q'
;;
;; rule Step_prems/fail-param:
;;   S |- PremParam(q) ~>_{} eps
;;   -- Step_param: S |- q ~> eps

rule Step_prems/IF-ctx:
  S |- IF e ~>_{} (IF e')
  -- Step_exp: S |- e ~> e'

rule Step_prems/IF-ctx-fail:
  S |- IF e ~>_{} eps
  -- Step_exp: S |- e ~> eps

rule Step_prems/LET-ctx1:
  S |- LET `{q*} e_1 `= e_2 ~>_{} (LET `{q*[[n] = q'_n]} e_1 `= e_2)
  -- Step_param: S |- q*[n] ~> q'_n

rule Step_prems/LET-ctx-fail1:
  S |- LET `{q*} e_1 `= e_2 ~>_{} eps
  -- Step_param: S |- q*[n] ~> eps

rule Step_prems/LET-ctx2:
  S |- LET `{q*} e_1 `= e_2 ~>_{} (LET `{q*} e'_1 `= e_2)
  -- Step_exp: S |- e_1 ~> e'_1

rule Step_prems/LET-ctx-fail2:
  S |- LET `{q*} e_1 `= e_2 ~>_{} eps
  -- Step_exp: S |- e_2 ~> eps

rule Step_prems/LET-ctx3:
  S |- LET `{q*} e_1 `= e_2 ~>_{} (LET `{q*} e_1 `= e'_2)
  -- Step_exp: S |- e_2 ~> e'_2

rule Step_prems/LET-ctx-fail3:
  S |- LET `{q*} e_1 `= e_2 ~>_{} eps
  -- Step_exp: S |- e_2 ~> eps

rule Step_prems/NOT-ctx:
  S |- NOT pr ~>_{} (NOT pr')
  -- Step_prems: S |- pr ~>_s pr'

rule Step_prems/NOT-ctx-fail:
  S |- NOT pr ~>_{} eps
  -- Step_prems: S |- pr ~>_s eps

rule Step_prems/ITER-ctx1:
  S |- ITER pr it ep* eq* ~>_{} (ITER pr' it ep* $subst_exppush(s, eq)*)
  -- Step_prems: S |- pr ~>_s pr'

rule Step_prems/ITER-ctx-fail1:
  S |- ITER pr it ep* eq* ~>_{} eps
  -- Step_prems: S |- pr ~>_s eps

rule Step_prems/ITER-ctx2:
  S |- ITER pr it ep* eq* ~>_{} (ITER pr it' ep* eq*)
  -- Step_iter: S |- it ~> it'

rule Step_prems/ITER-ctx-fail2:
  S |- ITER pr it ep* eq* ~>_{} eps
  -- Step_iter: S |- it ~> eps

rule Step_prems/ITER-ctx3:
  S |- ITER pr it ep* eq* ~>_{} (ITER pr it ep*[[n] = ep'_n] eq*)
  -- Step_exppull: S |- ep*[n] ~> ep'_n

rule Step_prems/ITER-ctx-fail3:
  S |- ITER pr it ep* eq* ~>_{} eps
  -- Step_exppull: S |- ep*[n] ~> eps

rule Step_prems/ITER-ctx4:
  S |- ITER pr it ep* eq* ~>_{} (ITER pr it ep* eq*[[n] = eq'_n])
  -- Step_exppush: S |- eq*[n] ~> eq'_n

rule Step_prems/ITER-ctx-fail4:
  S |- ITER pr it ep* eq* ~>_{} eps
  -- Step_exppush: S |- eq*[n] ~> eps


relation Step_quantprems: S |- quantprems ~> quantprems?

rule Step_quantprems/guess:
  S |- `{q*} pr* ~> `{eps} $subst_prem(s, pr')*
  -- Ok_subst: $storeenv(S) |- s : q*
  -- if (pr'*, s') = $refresh_prems(pr*)
  ;; Note: non-computational rule

rule Step_quantprems/ctx:
  S |- `{q*} pr* ~> `{q*} pr'*
  -- Step_prems: S |- pr* ~>_s pr'*

rule Step_quantprems/ctx-fail:
  S |- `{q*} pr* ~> eps
  -- Step_prems: S |- pr* ~>_s eps


;; Definitions

relation Step_inst: S |- inst ~> inst?
relation Step_clause: S |- clause ~> clause?


rule Step_inst/INST-ctx1:
  S |- INST `{q*} a* `=> t ~> INST `{q*[[n] = q'_n]} a* `=> t
  -- Step_param: S |- q*[n] ~> q'_n

rule Step_inst/INST-ctx-fail1:
  S |- INST `{q*} a* `=> t ~> eps
  -- Step_param: S |- q*[n] ~> eps

rule Step_inst/INST-ctx2:
  S |- INST `{q*} a* `=> t ~> INST `{q*} a*[[n] = a'_n] `=> t
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_inst/INST-ctx-fail2:
  S |- INST `{q*} a* `=> t ~> eps
  -- Step_arg: S |- a*[n] ~> eps


rule Step_clause/CLAUSE-ctx1:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> CLAUSE `{q*[[n] = q'_n]} a* `=> e `- pr*
  -- Step_param: S |- q*[n] ~> q'_n

rule Step_clause/CLAUSE-ctx-fail1:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> eps
  -- Step_param: S |- q*[n] ~> eps

rule Step_clause/CLAUSE-ctx2:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> CLAUSE `{q*} a*[[n] = a'_n] `=> e `- pr*
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_clause/CLAUSE-ctx-fail2:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> eps
  -- Step_arg: S |- a*[n] ~> eps

rule Step_clause/CLAUSE-ctx3:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> CLAUSE `{q*} a* `=> e' `- pr*
  -- Step_exp: S |- e ~> e'

rule Step_clause/CLAUSE-ctx-fail3:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_clause/CLAUSE-ctx4:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> CLAUSE `{q*} a* `=> $subst_exp(s, e) `- pr'*
  -- Step_prems: S |- pr* ~>_s pr'*

rule Step_clause/CLAUSE-ctx-fail4:
  S |- CLAUSE `{q*} a* `=> e `- pr* ~> eps
  -- Step_prems: S |- pr* ~>_s eps
