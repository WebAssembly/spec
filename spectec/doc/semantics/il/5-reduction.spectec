;;   -- Step_inst: S |- inst ~> inst'
;;
;; rule Step_typ/fail-inst:
;;   S |- TypInst(inst) ~> eps
;;   -- Step_inst: S |- inst ~> eps

rule Step_typ/VAR-ctx:
  S |- VAR x a* ~> VAR x a*[[n] = a'_n]
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_typ/VAR-ctx-fail:
  S |- VAR x a* ~> eps
  -- Step_arg: S |- a*[n] ~> eps

rule Step_typ/MATCH-ctx1:
  S |- MATCH x a* WITH inst* ~> MATCH x a*[[n] = a'_n] WITH inst*
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_typ/MATCH-ctx-fail1:
  S |- MATCH x a* WITH inst* ~> eps
  -- Step_arg: S |- a*[n] ~> eps

rule Step_typ/MATCH-ctx2:
  S |- MATCH x a* WITH inst* ~> MATCH x a* WITH inst*[[n] = inst'_n]
  -- Step_inst: S |- inst*[n] ~> inst'_n

rule Step_typ/MATCH-ctx-fail2:
  S |- MATCH x a* WITH inst* ~> eps
  -- Step_inst: S |- inst*[n] ~> eps

rule Step_typ/TUP-ctx:
  S |- TUP (x `: t)* ~> TUP (x `: t)*[[n] = (x*[n] `: t'_n)]
  -- Step_typ: S |- t*[n] ~> t'_n

rule Step_typ/TUP-ctx-fail:
  S |- TUP (x `: t)* ~> eps
  -- Step_typ: S |- t*[n] ~> eps

rule Step_typ/ITER-ctx:
  S |- ITER t it ~> ITER t' it
  -- Step_typ: S |- t ~> t'

rule Step_typ/ITER-ctx-fail:
  S |- ITER t it ~> eps
  -- Step_typ: S |- t ~> eps


;; Iterators

relation Step_iter: S |- iter ~> iter?
relation Step_exppull: S |- exppull ~> exppull?
relation Step_exppush: S |- exppush ~> exppush?


;; context IterExp(X : exp) : iter =
;;   | SUP x X
;;
;; rule Step_iter/ctx-exp:
;;   S |- IterExp(X) ~> IterExp(e')
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_iter/fail-exp:
;;   S |- IterExp(X) ~> eps
;;   -- Step_exp: S |- e ~> eps

rule Step_iter/SUP-ctx:
  S |- SUP x e ~> SUP x e'
  -- Step_exp: S |- e ~> e'

rule Step_iter/SUP-ctx-fail:
  S |- SUP x e ~> eps
  -- Step_exp: S |- e ~> eps


;; rule Step_exppull/ctx-typ:
;;   S |- x `: t `<- e  ~>  x `: t' `<- e
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_exppull/fail-typ:
;;   S |- x `: t `<- e  ~>  eps
;;   -- Step_typ: S |- t ~> eps
;;
;; rule Step_exppull/ctx-exp:
;;   S |- x `: t `<- e  ~>  x `: t `<- e'
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_exppull/fail-exp:
;;   S |- x `: t `<- e  ~>  eps
;;   -- Step_exp: S |- e ~> eps

rule Step_exppull/ctx1:
  S |- x `: t `<- e  ~>  x `: t' `<- e
  -- Step_typ: S |- t ~> t'

rule Step_exppull/ctx-fail1:
  S |- x `: t `<- e  ~>  eps
  -- Step_typ: S |- t ~> eps

rule Step_exppull/ctx2:
  S |- x `: t `<- e  ~>  x `: t `<- e'
  -- Step_exp: S |- e ~> e'

rule Step_exppull/ctx-fail2:
  S |- x `: t `<- e  ~>  eps
  -- Step_exp: S |- e ~> eps


;; rule Step_exppush/ctx-typ:
;;   S |- e `-> x `: t  ~>  e `-> x `: t'
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_exppush/fail-typ:
;;   S |- e `-> x `: t  ~>  eps
;;   -- Step_typ: S |- t ~> eps
;;
;; rule Step_exppush/ctx-exp:
;;   S |- e `-> x `: t  ~>  e' `-> x `: t
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_exppush/fail-exp:
;;   S |- e `-> x `: t  ~>  eps
;;   -- Step_exp: S |- e ~> eps

rule Step_exppush/ctx1:
  S |- e `-> x `: t  ~>  e' `-> x `: t
  -- Step_exp: S |- e ~> e'

rule Step_exppush/ctx-fail1:
  S |- e `-> x `: t  ~>  eps
  -- Step_exp: S |- e ~> eps

rule Step_exppush/ctx2:
  S |- e `-> x `: t  ~>  e `-> x `: t'
  -- Step_typ: S |- t ~> t'

rule Step_exppush/ctx-fail2:
  S |- e `-> x `: t  ~>  eps
  -- Step_typ: S |- t ~> eps


;; Expressions

relation Reduce_exp: S |- exp ~>* exp?
relation Step_exp: S |- exp ~> exp?
relation Step_expfield: S |- expfield ~> expfield?
relation Eq_exp: S |- exp == exp


rule Eq_exp:
  S |- e_1 == e_2
  -- Reduce_exp: S |- e_1 ~>* e'_1
  -- Reduce_exp: S |- e_2 ~>* e'_2
  -- if e'_1 = e'_2


rule Reduce_exp/refl:
  S |- e ~>* e

rule Reduce_exp/step:
  S |- e ~>* e''?
  -- Step_exp: S |- e ~> e'
  -- Reduce_exp: S |- e' ~>* e''?


rule Step_exp/UN-BOOL:
  S |- UN boolunop (BOOL b) ~> BOOL $boolun(boolunop, b)

rule Step_exp/UN-NUM:
  S |- UN numunop num ~> $numun(numunop, num)

rule Step_exp/BIN-BOOL:
  S |- BIN boolbinop (BOOL b_1) (BOOL b_2) ~> BOOL $boolbin(boolbinop, b_1, b_2)

rule Step_exp/BIN-NUM:
  S |- BIN numbinop num_1 num_2 ~> $numbin(numbinop, num_1, num_2)

rule Step_exp/CMP-EQ-true:
  S |- CMP EQ val_1 val_2 ~> BOOL true
  -- if val_1 = val_2

rule Step_exp/CMP-EQ-false:
  S |- CMP EQ val_1 val_2 ~> BOOL false
  -- if val_1 =/= val_2

rule Step_exp/CMP-NE-true:
  S |- CMP NE val_1 val_2 ~> BOOL true
  -- if val_1 =/= val_2

rule Step_exp/CMP-NE-false:
  S |- CMP NE val_1 val_2 ~> BOOL false
  -- if val_1 = val_2

rule Step_exp/CMP-NUM:
  S |- CMP numcmpop num_1 num_2 ~> BOOL $numcmp(numcmpop, num_1, num_2)


rule Step_exp/LIFT-none:
  S |- LIFT (OPT eps) ~> LIST eps

rule Step_exp/LIFT-some:
  S |- LIFT (OPT (e)) ~> LIST e

rule Step_exp/SEL-tup:
  S |- SEL (TUP e*) n ~> e_n
  -- if e_n = e*[n]

rule Step_exp/LEN-list:
  S |- LEN (LIST e^n) ~> NAT n

rule Step_exp/MEM-true:
  S |- MEM val_1 (LIST val_2*) ~> BOOL true
  -- if val_1 = val_2*[n]

rule Step_exp/MEM-false:
  S |- MEM val_1 (LIST val_2*) ~> BOOL false
  -- (if val_1 =/= val_2)*

rule Step_exp/CAT-opt1:
  S |- CAT (OPT e_1) (OPT eps) ~> OPT e_1

rule Step_exp/CAT-opt2:
  S |- CAT (OPT eps) (OPT e_2) ~> OPT e_2

rule Step_exp/CAT-list:
  S |- CAT (LIST e_1*) (LIST e_2*) ~> LIST e_1* e_2*

rule Step_exp/CAT-str:
  S |- CAT (STR t (a `= e_1 `- $trueqpr)*) (STR t (a `= e_2 `- $trueqpr)*) ~> STR t (a `= (CAT e_1 e_2) `- eps)*
  ;; Note: premises reset on result to trigger recheck


rule Step_exp/STR:
  S |- STR t (a `= e `- eps)* ~> STR t (a `= e `- $subst_quantprems($tupsubst(e, t'), `{q*} pr*))*
  -- Expand_typ: S |- t ~~ STRUCT tf*
  -- if (a `: t' `- `{q*} pr*) = tf*
  ;; Note: inject premises for yet unchecked intro form

rule Step_exp/INJ:
  S |- INJ t op e `- eps ~> INJ t op e `- $subst_quantprems($tupsubst(e, t'), `{q*} pr*)
  -- Expand_typ: S |- t ~~ VARIANT tc*
  -- if (op `: t' `- `{q*} pr*) <- tc*
  ;; Note: inject premises for yet unchecked intro form


rule Step_exp/ACC-ROOT:
  S |- ACC e ROOT ~> e

rule Step_exp/ACC-THE-some:
  S |- ACC e (THE p) ~> e'
  -- Step_exp: S |- ACC e p ~> OPT e'

rule Step_exp/ACC-THE-none:
  S |- ACC e (THE p) ~> eps
  -- Step_exp: S |- ACC e p ~> OPT eps

rule Step_exp/ACC-IDX-inb:
  S |- ACC e (IDX p (NAT n)) ~> e'_n
  -- Step_exp: S |- ACC e p ~> LIST e'*
  -- if n < |e'*|
  -- if e'_n = e'*[n]

rule Step_exp/ACC-IDX-oob:
  S |- ACC e (IDX p (NAT n)) ~> eps
  -- Step_exp: S |- ACC e p ~> LIST e'*
  -- if n >= |e'*|

rule Step_exp/ACC-SLICE-inb:
  S |- ACC e (SLICE p (NAT n) (NAT m)) ~> LIST e''*
  -- Step_exp: S |- ACC e p ~> LIST e'*
  -- if $(n + m) <= |e'*|
  -- if e''* = e'*[n : m]

rule Step_exp/ACC-SLICE-oob:
  S |- ACC e (SLICE p (NAT n) (NAT m)) ~> eps
  -- Step_exp: S |- ACC e p ~> LIST e'*
  -- if $(n + m) > |e'*|

rule Step_exp/ACC-DOT:
  S |- ACC e (DOT p a) ~> e'_n
  -- Step_exp: S |- ACC e p ~> STR t (a' `= e' `- $trueqpr)*
  -- if a'*[n] = a
  -- if e'*[n] = e'_n

rule Step_exp/ACC-PROJ-good:
  S |- ACC e (PROJ p mixop) ~> e'
  -- Step_exp: S |- ACC e p ~> INJ t mixop e' `- $trueqpr

rule Step_exp/ACC-PROJ-bad:
  S |- ACC e (PROJ p mixop) ~> eps
  -- Step_exp: S |- ACC e p ~> INJ t mixop' e' `- $trueqpr
  -- if mixop' =/= mixop


rule Step_exp/UPD-ROOT:
  S |- UPD e_1 ROOT e_2 ~> e_2

rule Step_exp/UPD-THE-some:
  S |- UPD e_1 (THE p) e_2 ~> UPD e_1 p (OPT e_2)
  -- Step_exp: S |- ACC e_1 p ~> OPT e'

rule Step_exp/UPD-THE-none:
  S |- UPD e_1 (THE p) e_2 ~> eps
  -- Step_exp: S |- ACC e_1 p ~> eps

rule Step_exp/UPD-IDX-inb:
  S |- UPD e_1 (IDX p (NAT n)) e_2 ~> UPD e_1 p (LIST e'*[[n] = e_2])
  -- Step_exp: S |- ACC e_1 p ~> LIST e'*
  -- if n < |e'*|

rule Step_exp/UPD-IDX-outb:
  S |- UPD e_1 (IDX p (NAT n)) e_2 ~> eps
  -- Step_exp: S |- ACC e_1 p ~> LIST e'*
  -- if n >= |e'*|

rule Step_exp/UPD-SLICE-inb:
  S |- UPD e_1 (SLICE p (NAT n) (NAT m)) (LIST e_2*) ~> UPD e_1 p (LIST e'*[[n : m] = e_2*])
  -- Step_exp: S |- ACC e_1 p ~> LIST e'*
  -- if $(n + m) <= |e'*|

rule Step_exp/UPD-SLICE-oob:
  S |- UPD e_1 (SLICE p (NAT n) (NAT m)) (LIST e_2*) ~> eps
  -- Step_exp: S |- ACC e_1 p ~> LIST e'*
  -- if $(n + m) > |e'*|

rule Step_exp/UPD-DOT:
  S |- UPD e_1 (DOT p a) e_2 ~> UPD e_1 p (STR t (a' `= e' `- $trueqpr)*[[n] = (a `= e_2 `- eps)])
  -- Step_exp: S |- ACC e_1 p ~> STR t (a' `= e' `- $trueqpr)*
  -- if a'*[n] = a
  ;; Note: premises reset on result for recheck

rule Step_exp/UPD-PROJ-good:
  S |- UPD e_1 (PROJ p mixop) e_2 ~> UPD e_1 p (INJ t mixop e_2 `- eps)
  -- Step_exp: S |- ACC e_1 p ~> INJ t mixop e' `- $trueqpr
  ;; Note: premises reset on result to trigger recheck

rule Step_exp/UPD-PROJ-bad:
  S |- UPD e_1 (PROJ p mixop) e_2 ~> eps
  -- Step_exp: S |- ACC e_1 p ~> INJ t mixop' e' `- $trueqpr
  -- if mixop' =/= mixop

rule Step_exp/EXT:
  S |- EXT e_1 p e_2 ~> UPD e_1 p (CAT (ACC e_1 p) e_2)


rule Step_exp/ITER-QUEST:
  S |- ITER e QUEST (x `: t `<- OPT e'?)* ~> OPT $subst_exp({EXP (x, e'')*}, e)?
  -- if e''*? = $transpose_(exp, e'?*)

rule Step_exp/ITER-PLUS:
  S |- ITER e PLUS (x `: t `<- LIST e'*)* ~> ITER e STAR (x `: t `<- LIST e'*)*
  -- if |e'**[0]| >= 1

rule Step_exp/ITER-STAR:
  S |- ITER e STAR (x `: t `<- LIST e'*)* ~> ITER e (SUP y (NAT n)) (x `: t `<- LIST e'*)*
  -- if |e'**[0]| = n
  -- Fresh_id: y FRESH

rule Step_exp/ITER-SUP-good:
  S |- ITER e (SUP y (NAT n)) (x `: t `<- LIST e'^n)* ~> LIST $subst_exp({EXP (x, e'')* (y, NAT i)}, e)^(i<n)
  -- if e''*^n = $transpose_(exp, e'^n*)

rule Step_exp/ITER-SUP-bad:
  S |- ITER e (SUP y (NAT n)) (x `: t `<- LIST e'^n')^k ~> eps
  -- if n'^k =/= n^k


rule Step_exp/CALL-apply:
  S |- CALL x a* ~> MATCH a* WITH clause*
  -- if (x, p* `-> t `= clause*) <- S.FUN


rule Step_exp/CVT-NUM-good:
  S |- CVT num nt_1 nt_2 ~> num'
  -- if num' = $numcvt(nt_2, num)

rule Step_exp/CVT-NUM-bad:
  S |- CVT num nt_1 nt_2 ~> eps
  -- otherwise


rule Step_exp/SUB-refl:
  S |- SUB e t t ~> e

rule Step_exp/SUB-SUB:
  S |- SUB (SUB e' t'_1 t'_2) t_1 t_2 ~> SUB e' t'_1 t_2

rule Step_exp/SUB-TUP:
  S |- SUB (TUP e^n) (TUP (x_1 `: t_1)^n) (TUP (x_2 `: t_2)^n) ~> TUP (SUB e $subst_typ(s_1, t_1) $subst_typ(s_2, t_2))^n
  -- if s_1 = {EXP (x_1, e^n[i])^(i<n)}
  -- if s_2 = {EXP (x_2, e^n[i])^(i<n)}

rule Step_exp/SUB-OPT:
  S |- SUB (OPT e?) (ITER t_1 QUEST) (ITER t_2 QUEST) ~> OPT (SUB e t_1 t_2)?

rule Step_exp/SUB-LIST:
  S |- SUB (LIST e*) (ITER t_1 STAR) (ITER t_2 STAR) ~> LIST (SUB e t_1 t_2)*

rule Step_exp/SUB-STR:
  S |- SUB (STR t_1 (at `= e `- $trueqpr)*) t_1 t_2 ~> STR t_2 (at' `= (SUB e t'_1 t'_2) `- eps)*
  -- if t_1 = MATCH x_1 WITH (INST `{} `=> STRUCT tf_1*)
  -- if t_2 = MATCH x_2 WITH (INST `{} `=> STRUCT tf_2*)
  -- (if (at' `: t'_1 `- `{q_1*} pr_1*) <- tf_1*)*
  -- (if (at' `: t'_2 `- `{q_2*} pr_2*) = tf_2)*
  ;; Note: premises reset on result to trigger recheck

rule Step_exp/SUB-INJ:
  S |- SUB (INJ t_1 op e `- $trueqpr) t_1 t_2 ~> INJ t_2 op (SUB e t'_1 t'_2) `- eps
  -- if t_1 = MATCH x_1 WITH (INST `{} `=> VARIANT tc_1*)
  -- if t_2 = MATCH x_2 WITH (INST `{} `=> VARIANT tc_2*)
  -- if (op `: t'_1 `- `{q_1*} pr_1*) <- tc_1*
  -- if (op `: t'_2 `- `{q_2*} pr_2*) <- tc_2*
  ;; Note: premises reset on result to trigger recheck


rule Step_exp/MATCH-match:
  S |- MATCH a* WITH (CLAUSE `{q*} a'* `=> epr) clause* ~>
    MATCH a''* WITH
      (CLAUSE `{q'*} a'''* `=> $subst_expprems(s, epr))
      (CLAUSE `{} a''* `=> (MATCH a* WITH clause*) `- eps)
  -- Step_argmatch: S |- `{q*} (a / a')*  ~>_s  `{q'*} (a'' / a''')*

rule Step_exp/MATCH-match-fail:
  S |- MATCH a* WITH (CLAUSE `{q*} a'* `=> e `- pr*) clause* ~>
    MATCH a''* WITH clause*
  -- Step_argmatch: S |- `{q*} (a / a')*  ~>_s  `{} eps

rule Step_exp/MATCH-guess:
  S |- MATCH a* WITH (CLAUSE `{q*} a'* `=> e `- pr*) clause* ~>
    MATCH a* WITH (CLAUSE `{} $subst_arg(s, a')* `=> e `- pr*) clause*
  -- Ok_subst: $storeenv(S) |- s : q*
  ;; Note: non-computational rule

rule Step_exp/MATCH-true:
  S |- MATCH eps WITH (CLAUSE `{} eps `=> e `- eps) clause* ~> e

rule Step_exp/MATCH-false:
  S |- MATCH eps WITH (CLAUSE `{} eps `=> e `- (IF (BOOL false)) pr*) clause* ~>
    MATCH eps WITH clause*


