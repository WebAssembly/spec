  S |- SEL e n ~> SEL e' n
  -- Step_exp: S |- e ~> e'

rule Step_exp/SEL-ctx-fail:
  S |- SEL e n ~> eps
  -- Step_exp: S |- e ~> eps


rule Step_exp/ACC-ctx1:
  S |- ACC e p ~> ACC e' p
  -- Step_exp: S |- e ~> e'

rule Step_exp/ACC-ctx-fail1:
  S |- ACC e p ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/ACC-ctx2:
  S |- ACC e p ~> ACC e p'
  -- Step_path: S |- p ~> p'

rule Step_exp/ACC-ctx-fail2:
  S |- ACC e p ~> eps
  -- Step_path: S |- p ~> eps

rule Step_exp/UPD-ctx1:
  S |- UPD e_1 p e_2 ~> UPD e_1' p e_2
  -- Step_exp: S |- e_1 ~> e_1'

rule Step_exp/UPD-ctx-fail1:
  S |- UPD e_1 p e_2 ~> eps
  -- Step_exp: S |- e_1 ~> eps

rule Step_exp/UPD-ctx2:
  S |- UPD e_1 p e_2 ~> UPD e_1 p' e_2
  -- Step_path: S |- p ~> p'

rule Step_exp/UPD-ctx-fail2:
  S |- UPD e_1 p e_2 ~> eps
  -- Step_path: S |- p ~> eps

rule Step_exp/UPD-ctx3:
  S |- UPD e_1 p e_2 ~> UPD e_1 p e_2'
  -- Step_exp: S |- e_2 ~> e_2'

rule Step_exp/UPD-ctx-fail3:
  S |- UPD e_1 p e_2 ~> eps
  -- Step_exp: S |- e_2 ~> eps


rule Step_exp/ITER-ctx1:
  S |- ITER e it ep* ~> ITER e' it ep*
  -- Step_exp: S |- e ~> e'

rule Step_exp/ITER-ctx-fail1:
  S |- ITER e it ep* ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/ITER-ctx2:
  S |- ITER e it ep* ~> ITER e it' ep*
  -- Step_iter: S |- it ~> it'

rule Step_exp/ITER-ctx-fail2:
  S |- ITER e it ep* ~> eps
  -- Step_iter: S |- it ~> eps

rule Step_exp/ITER-ctx3:
  S |- ITER e it ep* ~> ITER e it ep*[[n] = ep'_n]
  -- Step_exppull: S |- ep*[n] ~> ep'_n

rule Step_exp/ITER-ctx-fail3:
  S |- ITER e it ep* ~> eps
  -- Step_exppull: S |- ep*[n] ~> eps


rule Step_exp/CALL-ctx:
  S |- CALL x a* ~> CALL x a*[[n] = a'_n]
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_exp/CALL-ctx-fail:
  S |- CALL x a* ~> eps
  -- Step_arg: S |- a*[n] ~> eps


rule Step_exp/CVT-ctx:
  S |- CVT e nt_1 nt_2 ~> CVT e' nt_1 nt_2
  -- Step_exp: S |- e ~> e'

rule Step_exp/CVT-ctx-fail:
  S |- CVT e nt_1 nt_2 ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/SUB-ctx1:
  S |- SUB e t_1 t_2 ~> SUB e' t_1 t_2
  -- Step_exp: S |- e ~> e'

rule Step_exp/SUB-ctx-fail1:
  S |- SUB e t_1 t_2 ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/SUB-ctx2:
  S |- SUB e t_1 t_2 ~> SUB e t'_1 t_2
  -- Step_typ: S |- t_1 ~> t'_1

rule Step_exp/SUB-ctx-fail2:
  S |- SUB e t_1 t_2 ~> eps
  -- Step_typ: S |- t_1 ~> eps

rule Step_exp/SUB-ctx3:
  S |- SUB e t_1 t_2 ~> SUB e t_1 t'_2
  -- Step_typ: S |- t_2 ~> t'_2

rule Step_exp/SUB-ctx-fail3:
  S |- SUB e t_1 t_2 ~> eps
  -- Step_typ: S |- t_2 ~> eps


rule Step_exp/MATCH-ctx1:
  S |- MATCH a* WITH clause* ~> MATCH a*[[n] = a'_n] WITH clause*
  -- Step_arg: S |- a*[n] ~> a'_n

rule Step_exp/MATCH-ctx-fail1:
  S |- MATCH a* WITH clause* ~> eps
  -- Step_arg: S |- a*[n] ~> eps

rule Step_exp/MATCH-ctx2:
  S |- MATCH a* WITH clause* ~> MATCH a* WITH clause*[[n] = clause'_n]
  -- Step_clause: S |- clause*[n] ~> clause'_n

rule Step_exp/MATCH-ctx-fail2:
  S |- MATCH a* WITH clause* ~> eps
  -- Step_clause: S |- clause*[n] ~> eps


rule Step_expfield/ctx1:
  S |- a `= e `- qpr?  ~> a `= e' `- qpr?
  -- Step_exp: S |- e ~> e'

rule Step_expfield/ctx-fail1:
  S |- a `= e `- qpr? ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_expfield/ctx2:
  S |- a `= e `- qpr  ~> a `= e `- qpr'
  -- Step_quantprems: S |- qpr ~> qpr'

rule Step_expfield/ctx-fail2:
  S |- a `= e `- qpr ~> eps
  -- Step_quantprems: S |- qpr ~> eps


;; Paths

relation Step_path: S |- path ~> path?

;; context Path(X : path) : path =
;;   | X
;;   | THE Path(X)
;;   | IDX Path(X) e
;;   | SLICE Path(X) e_1 e_2
;;   | DOT Path(X) l
;;   | PROJ Path(X) l
;;
;; context PathExp(X : exp) : path =
;;   | Path(PathExp(X))
;;   | IDX p X
;;   | SLICE p X e_2 | SLICE p e_1 X
;;
;; rule Step_path/ctx-path:
;;   S |- Path(p) ~> Path(p')
;;   -- Step_path: S |- p ~> p'
;;
;; rule Step_path/fail-path:
;;   S |- Path(p) ~> eps
;;   -- Step_path: S |- p ~> eps
;;
;; rule Step_path/ctx-exp:
;;   S |- PathExp(e) ~> PathExp(e')
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_path/fail-exp:
;;   S |- PathExp(e) ~> eps
;;   -- Step_exp: S |- e ~> eps

rule Step_path/THE-ctx:
  S |- THE p ~> THE p'
  -- Step_path: S |- p ~> p'

rule Step_path/THE-ctx-fail:
  S |- THE p ~> eps
  -- Step_path: S |- p ~> eps

rule Step_path/IDX-ctx1:
  S |- IDX p e ~> IDX p' e
  -- Step_path: S |- p ~> p'

rule Step_path/IDX-ctx-fail1:
  S |- IDX p e ~> eps
  -- Step_path: S |- p ~> eps

rule Step_path/IDX-ctx2:
  S |- IDX p e ~> IDX p e'
  -- Step_exp: S |- e ~> e'

rule Step_path/IDX-ctx-fail2:
  S |- IDX p e ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_path/SLICE-ctx1:
  S |- SLICE p e_1 e_2 ~> SLICE p' e_1 e_2
  -- Step_path: S |- p ~> p'

rule Step_path/SLICE-ctx-fail1:
  S |- SLICE p e_1 e_2 ~> eps
  -- Step_path: S |- p ~> eps

rule Step_path/SLICE-ctx2:
  S |- SLICE p e_1 e_2 ~> SLICE p e'_1 e_2
  -- Step_exp: S |- e_1 ~> e'_1

rule Step_path/SLICE-ctx-fail2:
  S |- SLICE p e_1 e_2 ~> eps
  -- Step_exp: S |- e_1 ~> eps

rule Step_path/SLICE-ctx3:
  S |- SLICE p e_1 e_2 ~> SLICE p e_1 e'_2
  -- Step_exp: S |- e_2 ~> e'_2

rule Step_path/SLICE-ctx-fail3:
  S |- SLICE p e_1 e_2 ~> eps
  -- Step_exp: S |- e_2 ~> eps

rule Step_path/DOT-ctx:
  S |- DOT p a ~> DOT p' a
  -- Step_path: S |- p ~> p'

rule Step_path/DOT-ctx-fail:
  S |- DOT p a ~> eps
  -- Step_path: S |- p ~> eps

rule Step_path/PROJ-ctx:
  S |- PROJ p m ~> PROJ p' m
  -- Step_path: S |- p ~> p'

rule Step_path/PROJ-ctx-fail:
  S |- PROJ p m ~> eps
  -- Step_path: S |- p ~> eps


;; Matches

syntax argmatch = arg / arg
syntax expmatch = exp / exp

relation Step_argmatch: S |- `{quant*} argmatch* ~>_subst `{quant*} argmatch*?
relation Step_expmatch: S |- `{quant*} expmatch* ~>_subst `{quant*} expmatch*?
relation Step_argmatch_plain: S |- argmatch* ~> argmatch*?
relation Step_expmatch_plain: S |- expmatch* ~> expmatch*?

def $subst_argmatch(subst, argmatch) : argmatch
def $subst_expmatch(subst, expmatch) : expmatch

def $subst_argmatch(s, a / a') = $subst_arg(s, a) / $subst_arg(s, a')
def $subst_expmatch(s, e / e') = $subst_exp(s, e) / $subst_exp(s, e')


rule Step_argmatch/plain:
  S |- `{q*} (a / a')*  ~>_{}  `{q*} (a'' / a''')*
  -- Step_argmatch_plain: S |- (a / a')*  ~>  (a'' / a''')*

rule Step_argmatch/ctx:
  S |- `{q_1* q* q_2*} am_1* am am_2*  ~>_s 
    `{q_1* q'* $subst_param(s, q_2)*} (am_1* am'* $subst_argmatch(s, am_2)*)
  -- Step_argmatch: S |- `{q*} am ~>_s `{q'*} am'*

rule Step_argmatch/ctx-fail:
  S |- `{q_1* q* q_2*} am_1* am am_2*  ~>_s  `{} eps
  -- Step_argmatch: S |- `{q*} am ~>_s  `{} eps

rule Step_argmatch/TYP:
  S |- `{TYP x} (TYP t / TYP (VAR x))  ~>_{TYP (x, t)}  `{} (eps)

rule Step_argmatch/EXP:
  S |- `{EXP x `: t} (EXP e / EXP (VAR x))  ~>_{EXP (x, e)}  `{} (eps)

rule Step_argmatch/FUN:
  S |- `{FUN x `: p* `-> t} (FUN y / FUN x)  ~>_{FUN (x, y)}  `{} (eps)

rule Step_argmatch/GRAM:
  S |- `{GRAM x `: p* `-> t} (GRAM g / GRAM (VAR x))  ~>_{GRAM (x, g)}  `{} (eps)

rule Step_argmatch/EXP-exp:
  S |- `{q*} (EXP e / EXP e')  ~>_s  `{q'*} (EXP e'' / EXP e''')*
  -- Step_expmatch: S |- `{q*} (e / e')  ~>_s  `{q'*} (e'' / e''')*

rule Step_argmatch/EXP-fail:
  S |- `{q*} (EXP e / EXP e')  ~>_s  `{} eps
  -- Step_expmatch: S |- `{q*} (e / e')  ~>_s  `{} eps

;; TODO: EXP disjointness?


rule Step_argmatch_plain/ctx1:
  S |- a / a'  ~>  a'' / a'
  -- Step_arg: S |- a ~> a''

rule Step_argmatch_plain/ctx-fail1:
  S |- a / a'  ~>  eps
  -- Step_arg: S |- a ~> eps

rule Step_argmatch_plain/ctx2:
  S |- a / a'  ~>  a / a''
  -- Step_arg: S |- a' ~> a''

rule Step_argmatch_plain/ctx-fail2:
  S |- a / a'  ~>  eps
  -- Step_arg: S |- a' ~> eps


rule Step_expmatch/plain:
  S |- `{q*} (e / e')*  ~>_{}  `{q*} (e'' / e''')*
  -- Step_expmatch_plain: S |- (e / e')*  ~>  (e'' / e''')*

rule Step_expmatch/ctx:
  S |- `{q_1* q* q_2*} em_1* em em_2*  ~>_s 
    `{q_1* q'* $subst_param(s, q_2)*} (em_1* em'* $subst_expmatch(s, em_2)*)
  -- Step_expmatch: S |- `{q*} em ~>_s `{q'*} em'*

rule Step_expmatch/ctx-fail:
  S |- `{q_1* q* q_2*} em_1* em em_2*  ~>_s  `{} eps
  -- Step_expmatch: S |- `{q*} em ~>_s `{} eps

rule Step_expmatch/ITER-QUEST:
  S |- `{q*} (OPT e? / ITER e' QUEST (x `: t `<- e_p)*) ~>_{}
    `{$concat_(quant, (EXP x' `: t)*?) q*}
      ( (e / $subst_exp({EXP (x, VAR x')*}, e'))?
        (OPT (VAR x'')? / e_p)* )
  -- if x''?* = $transposeq_(id, x'*?)
  -- (Fresh_id: x' FRESH)*?
  ;; Note: inner match can only instantiate iteration variables

rule Step_expmatch/ITER-SUP:
  S |- `{q*} (LIST e^n / ITER e' (SUP y e_n) (x `: t `<- e_p)*) ~>_{}
    `{$concat_(quant, (EXP x' `: t)*^n) q*}
      ( (e / $subst_exp({EXP (y, NAT i) (x, VAR x')*}, e'))^(i<n)
        (NAT n / e_n) (LIST (VAR x'')^n / e_p)* )
  -- if x''^n* = $transpose_(id, x'*^n)
  -- (Fresh_id: x' FRESH)*^n
  ;; Note: inner match can only instantiate iteration variables


rule Step_expmatch_plain/ctx1:
  S |- e / e'  ~>  e'' / e'
  -- Step_exp: S |- e ~> e''

rule Step_expmatch_plain/ctx-fail1:
  S |- e / e'  ~>  eps
  -- Step_exp: S |- e ~> eps

rule Step_expmatch_plain/ctx2:
  S |- e / e'  ~>  e' / e''
  -- Step_exp: S |- e' ~> e''

rule Step_expmatch_plain/ctx-fail2:
  S |- e / e'  ~>  eps
  -- Step_exp: S |- e' ~> eps


rule Step_expmatch_plain/eq:
  S |- val / val  ~>  eps

rule Step_expmatch_plain/UN-PLUS-good:
  S |- num / UN PLUS e ~> num / e
  -- if ~ $isneg(num)

rule Step_expmatch_plain/UN-PLUS-bad:
  S |- num / UN PLUS e ~> eps
  -- otherwise

rule Step_expmatch_plain/UN-MINUS-good:
  S |- num / UN MINUS e ~> $numun(MINUS, num) / e
  -- if $isneg(num)

rule Step_expmatch_plain/UN-MINUS-bad:
  S |- num / UN MINUS e ~> eps
  -- otherwise

rule Step_expmatch_plain/CVT-good:
  S |- num / CVT e nt_1 nt_2 ~> num' / e
  -- if num' = $numcvt(nt_1, num)

rule Step_expmatch_plain/CVT-bad:
  S |- num / CVT e nt_1 nt_2 ~> eps
  -- otherwise

rule Step_expmatch_plain/TUP:
  S |- TUP e* / TUP e'* ~> (e / e')*

rule Step_expmatch_plain/INJ-good:
  S |- INJ t op e `- $trueqpr / INJ t' op' e' `- qpr? ~> e / e'
  -- if op = op'
  ;; Note: premises on pattern don't matter

rule Step_expmatch_plain/INJ-bad:
  S |- INJ t op e `- $trueqpr / INJ t' op' e' `- qpr? ~> eps
  -- otherwise
  ;; Note: premises on pattern don't matter

rule Step_expmatch_plain/OPT-good:
  S |- OPT e? / OPT e'? ~> ((e / e')?)
  -- if |e?| = |e'?|

rule Step_expmatch_plain/OPT-bad:
  S |- OPT e? / OPT e'? ~> eps
  -- otherwise

rule Step_expmatch_plain/LIST-good:
  S |- LIST e* / LIST e'* ~> (e / e')*
  -- if |e*| = |e'*|

rule Step_expmatch_plain/LIST-bad:
  S |- LIST e* / LIST e'* ~> eps
  -- otherwise

rule Step_expmatch_plain/LIFT-good:
  S |- LIST e? / LIFT e' ~> OPT e? / e'

rule Step_expmatch_plain/LIFT-bad:
  S |- LIST e* / LIFT e' ~> eps
  -- if |e*| > 1

rule Step_expmatch_plain/CAT-left-good:
  S |- LIST e_1* e_2* / CAT (LIST e'_1*) e'_2 ~> (LIST e_1* / LIST e'_1*) (LIST e_2* / e'_2)
  -- if |e_1*| = |e'_1*|

rule Step_expmatch_plain/CAT-left-bad:
  S |- LIST e_1* e_2* / CAT (LIST e'_1*) e'_2 ~> eps
  -- otherwise

rule Step_expmatch_plain/CAT-right-good:
  S |- LIST e_1* e_2* / CAT e'_1 (LIST e'_2*) ~> (LIST e_1* / e'_1) (LIST e_2* / LIST e'_2*)
  -- if |e_2*| = |e'_2*|

rule Step_expmatch_plain/CAT-right-bad:
  S |- LIST e_1* e_2* / CAT e'_1 (LIST e'_2*) ~> eps
  -- otherwise

rule Step_expmatch_plain/STR:
  S |- STR t ef* / STR t' ef'* ~> (e / e')*
  -- (if (l `= e' `- qpr'?) = ef')*
  -- (if (l `= e `- $trueqpr) <- ef*)*
  ;; Note: premises on pattern don't matter


rule Step_expmatch_plain/ITER-PLUS-good:
  S |- LIST e* / ITER e' PLUS (x `: t `<- e_p)* ~>
    LIST e* / ITER e' STAR (x `: t `<- e_p)*
  -- if |e*| >= 1

rule Step_expmatch_plain/ITER-PLUS-bad:
  S |- LIST eps / ITER e' PLUS (x `: t `<- e_p)* ~> eps

rule Step_expmatch_plain/ITER-STAR:
  S |- LIST e* / ITER e' STAR (x `: t `<- e_p)* ~>
    LIST e* / ITER e' (SUP y (NAT n)) (x `: t `<- e_p)*
  -- if |e*| = n
  -- Fresh_id: y FRESH


rule Step_expmatch_plain/SUB-SUB:
  S |- SUB e t_1 t_2 / SUB e' t'_1 t'_2 ~>
    SUB e t_1 t'_1 / e'
  -- Sub_typ: $storeenv(S) |- t_1 <: t'_1

;; TODO: disjointness?

rule Step_expmatch_plain/SUB-TUP:
  S |- TUP e^n / SUB e' (TUP (x_1 `: t'_1)^n) (TUP (x_2 `: t'_2)^n) ~>
    TUP (SUB e' $subst_typ(s_1, t'_1) $subst_typ(s_2, t'_2))^n / e'
  -- if s_1 = {EXP (x_1, SEL e i)^(i<n)}
  -- if s_2 = {EXP (x_2, SEL e i)^(i<n)}


;; Arguments

relation Reduce_arg: S |- arg ~>* arg?
relation Step_arg: S |- arg ~> arg?
relation Eq_arg: S |- arg == arg


rule Eq_arg:
  S |- a_1 == a_2
  -- Reduce_arg: S |- a_1 ~>* a'_1
  -- Reduce_arg: S |- a_2 ~>* a'_2
  -- if a'_1 = a'_2


rule Reduce_arg/refl:
  S |- a ~>* a

rule Reduce_arg/step:
  S |- a ~>* a''?
  -- Step_arg: S |- a ~> a'
  -- Reduce_arg: S |- a' ~>* a''?


;; rule Step_arg/ctx-typ:
;;   S |- TYP t ~> TYP t'
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_arg/fail-typ:
;;   S |- TYP t ~> eps
;;   -- Step_typ: S |- t ~> eps
;;
;; rule Step_arg/ctx-exp:
;;   S |- EXP e ~> EXP e'
;;   -- Step_exp: S |- e ~> e'
;;
;; rule Step_arg/fail-exp:
;;   S |- EXP e ~> eps
;;   -- Step_exp: S |- e ~> eps

rule Step_arg/EXP-ctx:
  S |- EXP e ~> EXP e'
  -- Step_exp: S |- e ~> e'

rule Step_arg/EXP-ctx-fail:
  S |- EXP e ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_arg/TYP-ctx:
  S |- TYP t ~> TYP t'
  -- Step_typ: S |- t ~> t'

rule Step_arg/TYP-ctx-fail:
  S |- TYP t ~> eps
  -- Step_typ: S |- t ~> eps


;; Parameters

relation Reduce_param: S |- param ~>* param?
relation Step_param: S |- param ~> param?


rule Reduce_param/refl:
  S |- p ~>* p

rule Reduce_param/step:
  S |- p ~>* p''?
  -- Step_param: S |- p ~> p'
  -- Reduce_param: S |- p' ~>* p''?


;; context Param(X : param) : param =
;;   | X
;;   | FUN x `: p_1* Param(X) p_2* `-> t
;;   | GRAM x `: p_1* Param(X) p_2* `-> t
;;
;; context ParamTyp(X : typ) : param =
;;   | Param(ParamTyp(X))
;;   | EXP x `: X
;;   | FUN x `: p* `-> X
;;   | GRAM x `: p* `-> X
;;
;; rule Step_param/ctx-param:
;;   S |- Param(p) ~> Param(p')
;;   -- Step_param: S |- p ~> p'
;;
;; rule Step_param/fail-param:
;;   S |- Param(p) ~> eps
;;   -- Step_param: S |- p ~> eps
;;
;; rule Step_param/ctx-typ:
;;   S |- ParamTyp(t) ~> ParamTyp(t')
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_param/fail-typ:
;;   S |- ParamTyp(t) ~> eps
;;   -- Step_typ: S |- t ~> eps

rule Step_param/EXP-ctx:
  S |- EXP x `: t ~> EXP x `: t'
  -- Step_typ: S |- t ~> t'

rule Step_param/EXP-ctx-fail:
  S |- EXP x `: t ~> eps
  -- Step_typ: S |- t ~> eps

rule Step_param/FUN-ctx1:
  S |- FUN x `: p* `-> t ~> FUN x `: p*[[n] = p'_n] `-> t'
  -- Step_param: S |- p*[n] ~> p'_n

rule Step_param/FUN-ctx-fail1:
  S |- FUN x `: p* `-> t ~> eps
  -- Step_param: S |- p*[n] ~> eps

rule Step_param/FUN-ctx2:
  S |- FUN x `: p* `-> t ~> FUN x `: p* `-> t'
  -- Step_typ: S |- t ~> t'

rule Step_param/FUN-ctx-fail2:
  S |- FUN x `: p* `-> t ~> eps
  -- Step_typ: S |- t ~> eps

rule Step_param/GRAM-ctx1:
  S |- GRAM x `: p* `-> t ~> GRAM x `: p*[[n] = p'_n] `-> t'
  -- Step_param: S |- p*[n] ~> p'_n

rule Step_param/GRAM-ctx-fail2:
  S |- GRAM x `: p* `-> t ~> eps
  -- Step_param: S |- p*[n] ~> eps

rule Step_param/GRAM-ctx2:
  S |- GRAM x `: p* `-> t ~> GRAM x `: p* `-> t'
  -- Step_typ: S |- t ~> t'

rule Step_param/FGRAM-ctx-fail2:
  S |- GRAM x `: p* `-> t ~> eps
  -- Step_typ: S |- t ~> eps


;; Premises

relation Reduce_prems: S |- prem* ~>* prem*?
relation Step_prems: S |- prem* ~>_subst prem*?
relation Eq_prems: S |- prem* == prem*


rule Eq_prems:
  S |- pr_1* == pr_2*
  -- Reduce_prems: S |- pr_1* ~>* pr'_1*
  -- Reduce_prems: S |- pr_2* ~>* pr'_2*
  -- if pr'_1* = pr'_2*


rule Reduce_prems/refl:
  S |- pr* ~>* pr*

rule Reduce_prems/step:
  S |- pr* ~>* pr''*?
  -- Step_prems: S |- pr* ~>_s pr'*
  -- Reduce_prems: S |- pr'* ~>* pr''*?


rule Step_prems/ctx:
  S |- pr_1* pr pr_2* ~>_(s ++ s') (pr_1* pr'* $subst_prem(s, pr'_2)*)
  -- Step_prems: S |- pr ~>_s pr'*
  -- if (pr'_2*, s') = $refresh_prems(pr_2*)

rule Step_prems/ctx-fail:
  S |- pr_1* pr pr_2* ~>_s eps
  -- Step_prems: S |- pr ~>_s eps


rule Step_prems/REL:
  S |- REL x a* `: e ~>_{} (pr'* (IF (CMP EQ $subst_exp(s ++ s', e') e)))
  -- if (x, p* `-> t `= rul*) <- S.REL
  -- if (RULE `{q*} (e' `- pr*)) <- $subst_rule($args_for_params(a*, p*), rul)*
  -- Ok_subst: $storeenv(S) |- s : q*
  -- if (pr'*, s') = $refresh_prems(pr*)
  ;; Note: non-computational rule

rule Step_prems/IF-true:
  S |- IF (BOOL true) ~>_{} (eps)

rule Step_prems/ELSE:
  S |- ELSE ~>_{} (IF (BOOL true))

rule Step_prems/LET-good:
  S |- LET `{(EXP x `: t)*} e_1 `= e_2 ~>_{EXP (x, e)*} []
  -- (if e = MATCH (EXP e_2) WITH (CLAUSE `{(EXP x `: t)*} (EXP e_1) `=> (VAR x) `- eps))*

rule Step_prems/LET-bad:
  S |- LET `{(EXP x `: t)*} e_1 `= e_2 ~>_{EXP (x, e)*} eps
  -- (if e = MATCH (EXP e_2) WITH eps)*

rule Step_prems/NOT-true:
  S |- NOT (IF (BOOL true)) ~>_{} (IF (BOOL false))

rule Step_prems/NOT-false:
  S |- NOT (IF (BOOL false)) ~>_{} (IF (BOOL true))

var ep : exppull
var eq : exppush

rule Step_prems/ITER-QUEST-good:
  S |- ITER pr QUEST (x_1 `: t_1 `<- OPT e_1?)* (e_2 `-> x_2 `: t_2)*
    ~>_{EXP (x_2, OPT $subst_exp(s', e'_2)?)*}
      $subst_prem({EXP (x_1, e'_1)*}, pr')?
  -- (if |e_1?| = |e_1?*[0]|)*
  -- if e'_1*? = $transpose_(exp, e_1?*)
  -- if e'_2?* = $transpose_(exp, e_2*?)
  -- (if (pr', s') = $refresh_prem(pr))?

rule Step_prems/ITER-QUEST-bad:
  S |- ITER pr QUEST (x_1 `: t_1 `<- OPT e_1?)* (e_2 `-> x_2 `: t_2)* ~>_{} eps
  -- if |e_1?*[i]| =/= |e_1?*[0]|

rule Step_prems/ITER-PLUS:
  S |- ITER pr PLUS (x_1 `: t_1 `<- LIST e_1^n)* (e_2 `-> x_2 `: t_2)* ~>_{}
    (ITER pr STAR (x_1 `: t_1 `<- LIST e_1^n)* (e_2 `-> x_2 `: t_2)*)
  -- if n*[0] >= 1

rule Step_prems/ITER-STAR:
  S |- ITER pr STAR (x_1 `: t_1 `<- LIST e_1^n)* (e_2 `-> x_2 `: t_2)* ~>_{}
    (ITER pr (SUP y (NAT n*[0])) (x_1 `: t_1 `<- LIST e_1^n)* (e_2 `-> x_2 `: t_2)*)
  -- Fresh_id: y FRESH

rule Step_prems/ITER-SUP-good:
  S |- ITER pr (SUP y (NAT n)) (x_1 `: t_1 `<- LIST e_1^n)* (e_2 `-> x_2 `: t_1)*
    ~>_{EXP (x_2, LIST $subst_exp(s', e'_2)^n)*}
      $subst_prem({EXP (x_1, e'_1)* (y, NAT i)}, pr')^(i<n)
  -- if e'_1*^n = $transpose_(exp, e_1^n*)
  -- if e'_2^n* = $transpose_(exp, e_2*^n)
  -- (if (pr', s') = $refresh_prem(pr))^n

rule Step_prems/ITER-SUP-bad:
  S |- ITER pr (SUP y (NAT n)) (x_1 `: t_1 `<- LIST e_1^n')* (e_2 `-> x_2 `: t_1)* ~>_{} eps
  -- if n'*[i] =/= n


