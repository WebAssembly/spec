;;   S |- ExpTyp(t) ~> ExpTyp(t')
;;   -- Step_typ: S |- t ~> t'
;;
;; rule Step_exp/fail-typ:
;;   S |- ExpTyp(t) ~> eps
;;   -- Step_typ: S |- t ~> eps
;;
;; rule Step_exp/ctx-path:
;;   S |- ExpPath(p) ~> ExpPath(p')
;;   -- Step_path: S |- p ~> p'
;;
;; rule Step_exp/fail-path:
;;   S |- ExpPath(p) ~> eps
;;   -- Step_path: S |- p ~> eps
;;
;; rule Step_exp/ctx-arg:
;;   S |- ExpArg(a) ~> ExpArg(a')
;;   -- Step_arg: S |- a ~> a'
;;
;; rule Step_exp/fail-arg:
;;   S |- ExpArg(a) ~> eps
;;   -- Step_arg: S |- a ~> eps
;;
;; rule Step_exp/ctx-inst:
;;   S |- ExpClause(cl) ~> ExpClause(cl')
;;   -- Step_clause: S |- cl ~> inst'
;;
;; rule Step_exp/fail-inst:
;;   S |- ExpClause(cl) ~> eps
;;   -- Step_clause: S |- cl ~> eps

rule Step_exp/UN-ctx:
  S |- UN op e ~> UN op e'
  -- Step_exp: S |- e ~> e'

rule Step_exp/UN-ctx-fail:
  S |- UN op e ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/BIN-ctx1:
  S |- BIN op e_1 e_2 ~> BIN op e_1' e_2
  -- Step_exp: S |- e_1 ~> e_1'

rule Step_exp/BIN-ctx-fail1:
  S |- BIN op e_1 e_2 ~> eps
  -- Step_exp: S |- e_1 ~> eps

rule Step_exp/BIN-ctx2:
  S |- BIN op e_1 e_2 ~> BIN op e_1' e_2
  -- Step_exp: S |- e_2 ~> e_2'

rule Step_exp/BIN-ctx-fail2:
  S |- BIN op e_1 e_2 ~> eps
  -- Step_exp: S |- e_2 ~> eps

rule Step_exp/CMP-ctx1:
  S |- CMP op e_1 e_2 ~> CMP op e_1' e_2
  -- Step_exp: S |- e_1 ~> e_1'

rule Step_exp/CMP-ctx-fail1:
  S |- CMP op e_1 e_2 ~> eps
  -- Step_exp: S |- e_1 ~> eps

rule Step_exp/CMP-ctx2:
  S |- CMP op e_1 e_2 ~> CMP op e_1' e_2
  -- Step_exp: S |- e_2 ~> e_2'

rule Step_exp/CMP-ctx-fail2:
  S |- CMP op e_1 e_2 ~> eps
  -- Step_exp: S |- e_2 ~> eps


rule Step_exp/OPT-ctx:
  S |- OPT e ~> OPT e'
  -- Step_exp: S |- e ~> e'

rule Step_exp/OPT-ctx-fail:
  S |- OPT e ~> eps
  -- Step_exp: S |- e ~> eps

rule Step_exp/LIST-ctx:
  S |- LIST e* ~> LIST e*[[n] = e'_n]
  -- Step_exp: S |- e*[n] ~> e'_n

rule Step_exp/LIST-ctx-fail:
  S |- LIST e* ~> eps
  -- Step_exp: S |- e*[n] ~> eps

rule Step_exp/TUP-ctx:
  S |- TUP e* ~> TUP e*[[n] = e'_n]
  -- Step_exp: S |- e*[n] ~> e'_n

rule Step_exp/TUP-ctx-fail:
  S |- TUP e* ~> eps
  -- Step_exp: S |- e*[n] ~> eps

rule Step_exp/STR-ctx1:
  S |- STR t ef* ~> STR t' ef*
  -- Step_typ: S |- t ~> t'

rule Step_exp/STR-ctx-fail1:
  S |- STR t ef* ~> eps
  -- Step_typ: S |- t ~> eps

rule Step_exp/STR-ctx2:
  S |- STR t ef* ~> STR t ef*[[n] = ef'_n]
  -- Step_expfield: S |- ef*[n] ~> ef'_n

rule Step_exp/STR-ctx-fail2:
  S |- STR t ef* ~> eps
  -- Step_expfield: S |- ef*[n] ~> eps

rule Step_exp/INJ-ctx1:
  S |- INJ t mixop e `- qpr? ~> INJ t' mixop e `- qpr?
  -- Step_typ: S |- t ~> t'

rule Step_exp/INJ-ctx-fail1:
  S |- INJ t mixop e `- qpr? ~> eps
