  -- Step_exp: S |- e_2 ~> eps

rule Step_exp/CAT-ctx1:
  S |- CAT e_1 e_2 ~> CAT e'_1 e_2
  -- Step_exp: S |- e_1 ~> e'_1

rule Step_exp/CAT-ctx-fail1:
