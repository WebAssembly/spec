  -- Step_exp: S |- e ~> eps

rule Step_exp/MEM-ctx1:
  S |- MEM e_1 e_2 ~> MEM e'_1 e_2
  -- Step_exp: S |- e_1 ~> e'_1

rule Step_exp/MEM-ctx-fail1:
